# LINE Messaging API (LINE Developersから取得)
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Google Sheets API (Google Cloud Consoleから取得)
# サービスアカウントのJSONキー全体を1行で貼り付ける
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"xxx","private_key_id":"xxx","private_key":"-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n","client_email":"xxx@xxx.iam.gserviceaccount.com"}

# Google SpreadsheetのID (URLの /spreadsheets/d/【この部分】/edit)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# オーナーへの通知 (オーナー自身のLINE User ID)
# ボットに「自分のID教えて」と送ると確認できます
OWNER_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# サーバーポート (Render.comでは自動設定されるので変更不要)
PORT=3000
